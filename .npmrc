# next-auth@5.0.0-beta.30 declares `peerOptional nodemailer@^7` while we're on
# nodemailer@^8 (for GHSA-vvjj-xcjg-gr5g CRLF CVE fix). The peer is optional
# (only used with the Email provider, we use Credentials), so the conflict is
# safe to ignore. Remove this line once next-auth v5 GA widens its peer range.
legacy-peer-deps=true
