# Neon: copy the URI from the dashboard (direct host is simplest for local dev).
# Avoid appending channel_binding=require — it often breaks Prisma/Node TLS.
# For serverless + pooler later: use a -pooler host with ?sslmode=require&pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&connect_timeout=15"

NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: email (registration / password reset)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
