# Neon Postgres (Prisma)
# Avoid channel_binding=require — it often breaks Prisma/Node TLS.
# Use connect_timeout=120 (or higher) for Neon cold start.
# The app uses @neondatabase/serverless Pool (WebSockets, often :443) via src/lib/prisma.ts — helps when raw TCP :5432 is blocked.
# prisma migrate / db push use DIRECT_URL over TCP; run those from a network that allows outbound 5432 (or use Neon SQL / CI).
#
# DATABASE_URL: pooled endpoint (hostname contains “-pooler”). Add &pgbouncer=true for Prisma + Neon PgBouncer.
# DIRECT_URL: same user/db/password but the non-pooler host — used by prisma migrate / db push / introspect.
# Performance: pick a Neon region close to users, then set Vercel `regions` in vercel.json to the matching area (see PERFORMANCE.md).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=120&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&connect_timeout=120"

# Neon Auth — Neon Console → Project → Branch → Auth → Configuration
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth"
# openssl rand -base64 32  (minimum 32 characters)
NEON_AUTH_COOKIE_SECRET="your-secret-at-least-32-characters-long"
