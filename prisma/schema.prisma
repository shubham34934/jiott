generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  player        Player?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  matchesCreated     Match[]       @relation("MatchCreatedBy")
  tournamentsCreated Tournament[]  @relation("TournamentCreatedBy")
  eventLogsUpdated   EventLog[]    @relation("EventLogUpdatedBy")
  feedbacks          Feedback[]
  pushSubscriptions  PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum FeedbackCategory {
  GENERAL
  BUG
  FEATURE
}

model Feedback {
  id           String            @id @default(uuid())
  category     FeedbackCategory  @default(GENERAL)
  message      String            @db.Text
  contactEmail String?
  pagePath     String?
  userId       String?
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())

  @@index([createdAt])
}

enum OtpType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id                  String             @id @default(uuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating              Int                @default(1000)
  matchesPlayed       Int                @default(0)
  matchesWon          Int                @default(0)
  /** Ranked (non-friendly) wins in a row; resets on loss. */
  currentWinStreak    Int                @default(0)
  /** Peak value of `currentWinStreak` over time (ranked matches only). */
  bestWinStreak       Int                @default(0)
  matchParticipations MatchParticipant[]
  teamsAsPlayer1      Team[]             @relation("TeamPlayer1")
  teamsAsPlayer2      Team[]             @relation("TeamPlayer2")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

enum MatchType {
  SINGLES
  DOUBLES
}

enum MatchStatus {
  ONGOING
  COMPLETED
  DISPUTED
}

model Match {
  id              String             @id @default(uuid())
  type            MatchType
  status          MatchStatus        @default(ONGOING)
  totalSets       Int                @default(3)
  pointsPerSet    Int                @default(11)
  isFriendly      Boolean            @default(false)
  createdBy       String
  createdByUser   User               @relation("MatchCreatedBy", fields: [createdBy], references: [id])
  participants    MatchParticipant[]
  sets            Set[]
  eventLogs       EventLog[]
  tournamentLinks TournamentMatch[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

enum TeamSide {
  A
  B
}

model MatchParticipant {
  id       String   @id @default(uuid())
  matchId  String
  playerId String
  team     TeamSide
  rankedRatingDelta Int?
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}

model Set {
  id         String @id @default(uuid())
  matchId    String
  setNumber  Int
  teamAScore Int    @default(0)
  teamBScore Int    @default(0)
  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, setNumber])
}

model EventLog {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  action        String
  previousValue Json?
  newValue      Json?
  updatedBy     String
  updatedByUser User     @relation("EventLogUpdatedBy", fields: [updatedBy], references: [id])
  matchId       String?
  match         Match?   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

enum TournamentStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

model Tournament {
  id             String           @id @default(uuid())
  name           String
  type           String           @default("SINGLE_ELIMINATION")
  matchType      MatchType
  status         TournamentStatus @default(CREATED)
  winnerTeamId   String?
  runnerUpTeamId String?
  teams          Team[]
  matches        TournamentMatch[]
  winnerTeam     Team?            @relation("TournamentWinner", fields: [winnerTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  runnerUpTeam   Team?            @relation("TournamentRunnerUp", fields: [runnerUpTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy      String
  createdByUser  User             @relation("TournamentCreatedBy", fields: [createdBy], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Team {
  id                  String            @id @default(uuid())
  tournamentId       String
  name               String?
  player1Id          String
  player2Id          String?
  tournament         Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1            Player            @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2            Player?           @relation("TeamPlayer2", fields: [player2Id], references: [id])
  matchesAsA         TournamentMatch[] @relation("TournamentMatchTeamA")
  matchesAsB         TournamentMatch[] @relation("TournamentMatchTeamB")
  matchesWon         TournamentMatch[] @relation("TournamentMatchWinner")
  tournamentsWon     Tournament[]      @relation("TournamentWinner")
  tournamentsRunnerUp Tournament[]     @relation("TournamentRunnerUp")

  @@unique([tournamentId, player1Id])
}

enum TournamentMatchStatus {
  LOCKED
  READY
  ONGOING
  COMPLETED
}

model TournamentMatch {
  id           String                @id @default(uuid())
  tournamentId String
  round        Int
  position     Int
  teamAId      String?
  teamBId      String?
  winnerId     String?
  matchId      String?               @unique
  status       TournamentMatchStatus @default(LOCKED)
  tournament   Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamA        Team?                 @relation("TournamentMatchTeamA", fields: [teamAId], references: [id])
  teamB        Team?                 @relation("TournamentMatchTeamB", fields: [teamBId], references: [id])
  winner       Team?                 @relation("TournamentMatchWinner", fields: [winnerId], references: [id])
  match        Match?                @relation(fields: [matchId], references: [id], onDelete: SetNull)
  dependedOnBy MatchDependency[]     @relation("DependsOn")
  dependsOn    MatchDependency[]     @relation("DependentMatch")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model MatchDependency {
  id               String          @id @default(uuid())
  matchId          String
  dependsOnMatchId String
  slot             TeamSide
  match            TournamentMatch @relation("DependentMatch", fields: [matchId], references: [id], onDelete: Cascade)
  dependsOnMatch   TournamentMatch @relation("DependsOn", fields: [dependsOnMatchId], references: [id], onDelete: Cascade)

  @@unique([matchId, slot])
}
